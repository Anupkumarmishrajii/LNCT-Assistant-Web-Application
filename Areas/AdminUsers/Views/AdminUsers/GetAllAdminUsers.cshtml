@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using DTO
@model List<AdminUsersDTO>
@{
    ViewData["Title"] = "GetAllAdminUsers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<br />
<br />
<br />
<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">All Admin..!</h2>
        </div>
        <hr />
        <h2 class="col-auto text-center text-danger" style="color:black">No Authrozition for any modification within Admin data..!</h2>
        <h2 class="col-auto text-center text-danger" style="color:black">It is getting controlled by Supervisor through backend for security purpose so it is suggested to contect to your Supervisor in case of any doubt..!</h2>

        <hr />

        <div class="data-table mt-2">
            <table id="tblAdmin" class="table table-striped table-responsive">
                <thead>
                    <tr>
                        <th style="border: 1px solid black;">Name</th>
                        <th style="border: 1px solid black;">Email</th>
                        <th style="border: 1px solid black;">Status</th>
                        <th style="border: 1px solid black;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (AdminUsersDTO objAdminUsersDTO in Model)
                        {
                            <tr>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objAdminUsersDTO.Name)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objAdminUsersDTO.Email)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objAdminUsersDTO.Status)</td>
                                <td style="border: 1px solid black; vertical-align:top;"><h4 class="text-danger">Not Authorized..!</h4></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-info" type="button">Home</a>
            <a asp-area="AdminUsers" asp-controller="AdminUsers" asp-action="DashBoard" class="btn btn-secondary " type="button">Back</a>
        </div>
    </div>
</div>


<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#tblAdmin').DataTable({
            "paging": true,
            "ordering": false,
            "info": false,
            "searching": false,
            "lengthMenu": [[3, 5, 10, -1], [3, 5, 10, "All"]] // Limit the options to 3, 5, 10, or show all
        });
    });
</script>
<style>
    /* CSS for pagination */
    .dataTables_wrapper .dataTables_paginate {
        text-align: right; /* Align pagination to the right */
        margin-top: 1em; /* Add some top margin */
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.5em 1em;
            margin-left: 2px;
            border-radius: 2px;
            background-color: #007bff;
            color: #ffffff;
            border: none;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background-color: #0056b3;
                color: #ffffff;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background-color: #0056b3;
                color: #ffffff;
            }

</style>




