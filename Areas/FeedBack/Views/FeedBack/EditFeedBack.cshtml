@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model WebLNCTAssistant.Areas.FeedBack.Models.FeedBackModel
@{
    ViewData["Title"] = "EditFeedBack";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<br />
<br />
<br />
<br />
<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">Only Admin..!</h2>
        </div>
        <hr />
        <form asp-area="FeedBack" asp-controller="FeedBack" asp-action="EditFeedBack" method="post">
            <input type="hidden" asp-for="FeedBackID" />
            <div class="row g-3 align-items-center mt-3">
                <div class="col-2">
                    <label class="col-form-label"><b>Name:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Name" class="form-control">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Email:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="email" asp-for="Email" class="form-control">
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Mobile:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Mobile" class="form-control">
                    <span asp-validation-for="Mobile" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>FeedBack Type:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="FeedBackType" class="form-control">
                        <option value="">--Select--</option>
                        <option value="Technical"> Technical </option>
                        <option value="Acedemic"> Acedemic </option>
                        <option value="Other"> Other </option>
                    </select>
                    <span asp-validation-for="FeedBackType" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Subject:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Subject" class="form-control">
                    <span asp-validation-for="Subject" class="text-danger"></span>
                </div>
            </div>


            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>FeedBack Message:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <textarea asp-for="FeedBackMessage" class="form-control card-text"></textarea>
                    <span asp-validation-for="FeedBackMessage" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Priority Lavel:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="Priority_Level" class="form-control">
                        <option value="Low"> Low </option>
                        <option value="Higher"> Higher! </option>
                        <option value="Danger"> Danger..! </option>
                    </select>
                    <span asp-validation-for="Priority_Level" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Status:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="Status" class="form-control">
                        <option value="PENDING"> Pending </option>
                        <option value="SOLVED"> Solved </option>
                        <option value="DELETED"> Delete </option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
            <hr />
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-info" type="button">Home</a>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-secondary " type="button">Back</a>
                <button class="btn btn-primary" type="submit">Update</button>
            </div>
        </form>
    </div>
</div>


