@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "DashBoard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<br />
<br />
<br />

<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img  src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">Admin..!</h2>
        </div>
        <hr />

        <div class="row row-cols-1 row-cols-md-2 g-4">
            <div class="col">
                <div class="card">
                    <img src="https://th.bing.com/th/id/OIP.i5kRxCESTutRU_wI2gGeIQHaD4?rs=1&pid=ImgDetMain" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">All Pending lead</h5>
                        <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
                        <a asp-area="Users" asp-controller="Users" asp-action="GetAllUsers" class="btn btn-primary"> Go </a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card">
                    <img src="https://th.bing.com/th/id/OIP.i5kRxCESTutRU_wI2gGeIQHaD4?rs=1&pid=ImgDetMain" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">All Admin</h5>
                        <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
                        <a asp-area="AdminUsers" asp-controller="AdminUsers" asp-action="GetAllAdminUsers" class="btn btn-primary"> Go </a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card">
                    <img src="https://th.bing.com/th/id/OIP.i5kRxCESTutRU_wI2gGeIQHaD4?rs=1&pid=ImgDetMain" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">All pending Admissions.</h5>
                        <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content.</p>
                        <a asp-area="Admission" asp-controller="Admission" asp-action="GetAllAdmission" class="btn btn-primary"> Go </a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card">
                    <img src="https://th.bing.com/th/id/OIP.i5kRxCESTutRU_wI2gGeIQHaD4?rs=1&pid=ImgDetMain" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">All FeedBack</h5>
                        <p class="card-text">This is a longer card with supporting text below as a natural lead-in to additional content.</p>
                        <a asp-area="FeedBack" asp-controller="FeedBack" asp-action="GetAllFeedBack" class="btn btn-primary"> Go </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    body {
        background: linear-gradient(135deg, #fdf2e9, #F6B1B3);
    }
</style>