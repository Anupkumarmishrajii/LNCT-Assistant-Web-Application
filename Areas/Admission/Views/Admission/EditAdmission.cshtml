@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model WebLNCTAssistant.Areas.Admission.Models.AdmissionModel
@{
    ViewData["Title"] = "EditAdmission";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<br />
<br />
<br />
<br />
<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">Only  Admin..!</h2>
        </div>
        <hr />
        <form asp-area="Admission" asp-controller="Admission" asp-action="EditAdmission" method="post">
            <input type="hidden" asp-for="AdmissionID" />
            <div class="row g-3 align-items-center mt-3">
                <div class="col-2">
                    <label class="col-form-label"><b>Name:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Name" class="form-control">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Email:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="email" asp-for="Email" class="form-control">
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>DOB:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="datetime-local" asp-for="DOB" class="form-control">
                    <span asp-validation-for="DOB" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Gender:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="Gender" class="form-control">
                        <option value="">--Select--</option>
                        <option value="Male"> Male </option>
                        <option value="Female"> Female </option>
                        <option value="Other"> Other </option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Disability:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    Yes..! <input asp-for="Disability" type="radio" value="true">
                    No..! <input asp-for="Disability" type="radio" value="false">
                    <span asp-validation-for="Disability" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Address:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <textarea asp-for="Address" class="form-control card-text"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Mobile:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Mobile" class="form-control">
                    <span asp-validation-for="Mobile" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Alternate Mobile:</b></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="AlternateMobile" class="form-control">
                    <span asp-validation-for="AlternateMobile" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Previous Institute:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Previous_Institute" class="form-control">
                    <span asp-validation-for="Previous_Institute" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Year of passing:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Year_PassedOut" class="form-control">
                    <span asp-validation-for="Year_PassedOut" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Score:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Score" class="form-control">
                    <span asp-validation-for="Score" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Desired Program:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Desired_Program" class="form-control">
                    <span asp-validation-for="Desired_Program" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Lnaguage:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="Language" class="form-control">
                        <option value="">--Select--</option>
                        <option value="Hindi"> Hindi </option>
                        <option value="English"> English </option>
                        <option value="Hinglish"> Hinglish </option>
                    </select>
                    <span asp-validation-for="Language" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Reference:</b></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Reference" class="form-control">
                    <span asp-validation-for="Reference" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Status:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="Status" class="form-control">
                        <option value="PENDING"> Pending </option>
                        <option value="COMPLEATED"> Compleated </option>
                        <option value="DELETED"> Delete </option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
            <hr />
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-info" type="button">Home</a>
                <a asp-area="AdminUsers" asp-controller="AdminUsers" asp-action="DashBoard" class="btn btn-secondary " type="button">Back</a>
                <button class="btn btn-primary" type="submit">Update</button>
            </div>
        </form>
    </div>
</div>
