@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using DTO
@model List<FeedBackDTO>
@{
    ViewData["Title"] = "GetAllFeedBack";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<br />
<br />
<br />

<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">All Pending FeedBack Data..!</h2>
        </div>
        <hr />
        <div class="data-table mt-2">
            <table id="tblFeedback" class="table table-striped table-responsive">
                <thead>
                    <tr>
                        <th style="border: 1px solid black;">Name</th>
                        <th style="border: 1px solid black;">Email</th>
                        <th style="border: 1px solid black;">Mobile</th>
                        <th style="border: 1px solid black;">FeedBack Type</th>
                        <th style="border: 1px solid black;">Subject</th>
                        <th style="border: 1px solid black;">FeedBack Message</th>
                        <th style="border: 1px solid black;">Status</th>
                        <th style="border: 1px solid black;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (FeedBackDTO objFeedBackDTO in Model)
                        {
                            <tr>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objFeedBackDTO.Name)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objFeedBackDTO.Email)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objFeedBackDTO.Mobile)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objFeedBackDTO.FeedBackType)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objFeedBackDTO.Subject)</td>
                                <td style="border: 1px solid black; vertical-align:top; justify-content:center">
                                    <a role="button" class="btn btn-info" asp-area="FeedBack" asp-controller="FeedBack" asp-action="FeedBackMessageDetail" asp-route-feedbackid1="@objFeedBackDTO.FeedBackID">Details</a>
                                </td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objFeedBackDTO.Status)</td>
                                <td style="border: 1px solid black; vertical-align:top; justify-content:center">
                                    <a href="@Url.Action("EditFeedBack","FeedBack", new { feedbackid1 = objFeedBackDTO.FeedBackID })" class="btn btn-primary no-underline">Edit</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-info" type="button">Home</a>
            <a asp-area="AdminUsers" asp-controller="AdminUsers" asp-action="DashBoard" class="btn btn-secondary " type="button">Back</a>
        </div>

    </div>
</div>




<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#tblFeedback').DataTable({
            "paging": true,
            "ordering": false,
            "info": false,
            "searching": false,
            "lengthMenu": [[3, 5, 10, -1], [3, 5, 10, "All"]] // Limit the options to 3, 5, 10, or show all
        });
    });
</script>
<style>
    /* CSS for pagination */
    .dataTables_wrapper .dataTables_paginate {
        text-align: right; /* Align pagination to the right */
        margin-top: 1em; /* Add some top margin */
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.5em 1em;
            margin-left: 2px;
            border-radius: 2px;
            background-color: #007bff;
            color: #ffffff;
            border: none;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background-color: #0056b3;
                color: #ffffff;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background-color: #0056b3;
                color: #ffffff;
            }

</style>



