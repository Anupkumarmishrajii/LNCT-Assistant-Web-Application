@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using DTO
@model List<UsersDTO>

@{
    ViewData["Title"] = "GetAllUsers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<br />
<br />
<br />
<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">All Pending Data..!</h2>
        </div>
        <hr />

        <div class="data-table mt-2">
            <table id="tblUsers" class="table table-striped table-responsive">
                <thead>
                    <tr>
                        <th style="border: 1px solid black;">Name</th>
                        <th style="border: 1px solid black;">Email</th>
                        <th style="border: 1px solid black;">IsLNCTIan</th>
                        <th style="border: 1px solid black;">As_a</th>
                        <th style="border: 1px solid black;">HigherEaducation</th>
                        <th style="border: 1px solid black;">Mobile</th>
                        <th style="border: 1px solid black;">Status</th>
                        <th style="border: 1px solid black;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (UsersDTO objUsersDTO in Model)
                        {
                            <tr>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.Name)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.Email)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.IsLNCTIan)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.As_a)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.HigherEaducation)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.Mobile)</td>
                                <td style="border: 1px solid black; vertical-align:top;">@Html.Raw(objUsersDTO.Status)</td>
                                <td style="border: 1px solid black; vertical-align:top; justify-content:center">
                                    <a href="@Url.Action("EditUsers","Users", new { userid1 = objUsersDTO.UsersID })" class="btn btn-primary no-underline">Edit</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-info" type="button">Home</a>
            <a asp-area="AdminUsers" asp-controller="AdminUsers" asp-action="DashBoard" class="btn btn-secondary " type="button">Back</a>
        </div>

    </div>
</div>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.js"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $('#tblUsers').DataTable({
            "paging": true,
            "ordering": false,
            "info": false,
            "searching": false,
            "lengthMenu": [[3, 5, 10, -1], [3, 5, 10, "All"]] // Limit the options to 3, 5, 10, or show all
        });
    });
</script>
<style>
    /* CSS for pagination */
    .dataTables_wrapper .dataTables_paginate {
        text-align: right; /* Align pagination to the right */
        margin-top: 1em; /* Add some top margin */
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.5em 1em;
            margin-left: 2px;
            border-radius: 2px;
            background-color: #007bff;
            color: #ffffff;
            border: none;
        }

            .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
                background-color: #0056b3;
                color: #ffffff;
            }

            .dataTables_wrapper .dataTables_paginate .paginate_button.current {
                background-color: #0056b3;
                color: #ffffff;
            }


</style>



