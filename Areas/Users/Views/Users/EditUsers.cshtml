@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model WebLNCTAssistant.Areas.Users.Models.UsersModel
@{
    ViewData["Title"] = "EditUsers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<br />
<br />
<br />
<br />
<div class="card mt-5" style="background-color:antiquewhite">
    <div class="card-header">
        <img src="https://www.admissionindia.net/uploads/colleges/31/logo-1.png" style="height:70px" />
    </div>
    <div class="card-body">
        <div style="text-align:right;">
            <h2 class="col-11 text-center" style="color:black">Only Admin..!</h2>
        </div>
        <hr />
        <form asp-area="Users" asp-controller="Users" asp-action="EditUsers" method="post">
            <input type="hidden" asp-for="UsersID" />
            <div class="row g-3 align-items-center mt-3">
                <div class="col-2">
                    <label class="col-form-label"><b>Name:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Name" class="form-control">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Email:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="email" asp-for="Email" class="form-control">
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>LNCTian..?:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    Yes..! <input asp-for="IsLNCTIan" type="radio" value="true">
                    No..! <input asp-for="IsLNCTIan" type="radio" value="false">
                    <span asp-validation-for="IsLNCTIan" class="text-danger"></span>
                </div>

            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>As a:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="As_a" class="form-control">
                        <option value="">--Select--</option>
                        <option value="Teacher"> Teacher </option>
                        <option value="Student"> Student </option>
                        <option value="Parent"> Parent </option>
                    </select>
                    <span asp-validation-for="As_a" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Higher Education:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="HigherEaducation" class="form-control">
                        <option value="">--Select--</option>
                        <option value="10th"> 10th </option>
                        <option value="12th"> 12th </option>
                        <option value="UG"> UG </option>
                        <option value="PG"> PG </option>
                        <option value="PHD"> PHD </option>
                    </select>
                    <span asp-validation-for="HigherEaducation" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Mobile No.:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <input type="text" asp-for="Mobile" class="form-control">
                    <span asp-validation-for="Mobile" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 align-items-center mt-2">
                <div class="col-2">
                    <label class="col-form-label"><b>Status:</b><span class="text-danger">*</span></label>
                </div>
                <div class="col-10">
                    <select asp-for="Status" class="form-control">
                        <option value="PENDING"> Pending </option>
                        <option value="COMPLEATED"> Compleated </option>
                        <option value="DELETED"> Delete </option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>
            <hr />
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-info" type="button">Home</a>
                <a asp-area="AdminUsers" asp-controller="AdminUsers" asp-action="DashBoard" class="btn btn-secondary " type="button">Back</a>
                <button class="btn btn-primary" type="submit">Update</button>
            </div>
        </form>
    </div>
</div>

