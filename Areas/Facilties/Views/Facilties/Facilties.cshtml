            content: "";
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 20vw;
            background: url("") green;
            background-size: 100%;
            transform: translate(0, 100%);
        }

    .section-bubble1 {
        background-color: #fdf2e9;
    }

        .section-bubble1:after {
